<Shell
    x:Class="MyFinanceApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MyFinanceApp">

    <FlyoutItem Title="Главная">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Добавить">
        <ShellContent ContentTemplate="{DataTemplate local:AddTransactionPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Отчеты">
        <ShellContent ContentTemplate="{DataTemplate local:ReportsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Категории">
        <ShellContent ContentTemplate="{DataTemplate local:CategoriesPage}" />
    </FlyoutItem>

</Shell>